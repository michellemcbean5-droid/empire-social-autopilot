# Q-Empire Social Autopilot — environment variables
# Copy this to .env and fill in your values.

# LLM API Key (Anthropic Claude). Without it, the template content engine is used.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Content model
SOCIAL_LLM_MODEL=claude-sonnet-4-20250514

# 1 = simulate publishing (safe, default). 0 = attempt real publishing.
SOCIAL_DRY_RUN=1

# Where saved content calendars are written
SOCIAL_OUTPUT_DIR=output/social
